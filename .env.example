# ============================================================
# Trading-Bot-v2 — Environment Variables
# Copy to .env and fill in all values
# NEVER commit .env to git
# ============================================================

# ---- Alpaca Markets ----------------------------------------
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
# paper = paper trading (safe), live = real money
TRADING_MODE=paper

# ---- PostgreSQL --------------------------------------------
POSTGRES_USER=trading
POSTGRES_PASSWORD=change_this_strong_password_here

# ---- API ---------------------------------------------------
API_SECRET=change_this_api_secret_key_here
# Internal URL used by the bot to post telemetry
API_BASE_URL=http://api:4000

# ---- Telegram Notifications (optional) --------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Dashboard Auth (basic) --------------------------------
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_dashboard_password
